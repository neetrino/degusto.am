
# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Database Configuration (required — do not leave empty)
#
# --- Vercel Production (Neon PostgreSQL) ---
# - DATABASE_URL: use Neon’s **pooled** connection string (host contains `-pooler`, e.g. `ep-xxx-pooler...neon.tech`).
#   On Vercel with the Neon driver adapter, the app uses HTTP fetch (not WebSocket) and does **not** append `pgbouncer=true` to the URL.
#   After deploy, open `/api/health/db` — should be `{"status":"ok","database":"up"}` (no secrets in response).
# - DIRECT_URL: Neon’s **direct** (non-pooled) URL — for `prisma migrate` / introspection only. Do not use direct URL as DATABASE_URL on serverless.
# - Set both in: Vercel → Project → Settings → Environment Variables → Production (and Preview if needed).
# - On Vercel + Neon, the app auto-enables `@prisma/adapter-neon` (HTTP) so the RHEL query engine binary is not required.
# - Optional: `PRISMA_NEON_ADAPTER=0` forces TCP + `pgbouncer=true` (needs `binaryTargets` rhel in schema + engine in bundle).
# - Optional: `PRISMA_NEON_ADAPTER=1` forces the Neon adapter on any host (e.g. local Neon testing).
#
# --- Local ---
# Local example: postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
# You may set DIRECT_URL identical to DATABASE_URL for a single local Postgres instance.
#
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/whiteshop"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/whiteshop"
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"
# Build-only: skip DB URL validation (CI without secrets). Never set in Vercel Production.
# SKIP_DB_URL_VALIDATION="1"


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""
