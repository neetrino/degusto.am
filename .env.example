
# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
# Public site origin (CORS, server-side fetch). On Vercel set to https://your-domain
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Leave empty to use same-origin Next.js API routes (/api/v1/...). Do NOT set to localhost on Vercel.
NEXT_PUBLIC_API_URL=""


DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/whiteshop"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/whiteshop"


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"


# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
NEXT_PUBLIC_R2_PUBLIC_URL=""

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""
