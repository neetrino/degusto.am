{
  "buildCommand": "pnpm run build:with-migrate",
  "framework": "nextjs",
  "installCommand": "pnpm install && pnpm run db:generate && node src/scripts/ensure-prisma-rhel-engine.js",
  "devCommand": "pnpm run dev",
  "env": { "NODE_ENV": "production" },
  "functions": {
    "src/app/api/v1/admin/products/route.ts": { "maxDuration": 30 },
    "src/app/api/v1/admin/products/upload-images/route.ts": { "maxDuration": 30 }
  }
}
